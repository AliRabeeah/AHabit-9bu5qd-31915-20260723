{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "node": "20.18.0",
      "android": {
        "buildType": "apk",
        "env": {
          "EAS_SKIP_AUTO_FINGERPRINT": "1"
        }
      }
    },
    "production": {
      "node": "20.18.0",
      "android": {
        "buildType": "app-bundle",
        "env": {
          "EAS_SKIP_AUTO_FINGERPRINT": "1"
        }
      }
    }
  }
}
